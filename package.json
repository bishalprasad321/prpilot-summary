{
  "name": "action-agentic-pr-doc",
  "version": "1.0.0",
  "description": "Generate a pull request description using AI based on the changes made in the PR.",
  "author": "Bishal Prasad",
  "main": "dist/index.js",
  "scripts": {
    "clean": "node scripts/clean.js",
    "build": "npm run clean && tsc --project tsconfig.json && ncc build lib/index.js -o dist --source-map --license licenses.txt",
    "watch": "tsc --watch --project tsconfig.json",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.js",
    "all": "npm run lint && npm run format:check && npm run typecheck && npm run build",
    "prepublishOnly": "npm run all",
    "prepare": "husky install"
  },
  "keywords": [
    "github",
    "github-action",
    "pull-request",
    "ai",
    "gpt",
    "pr-description"
  ],
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@octokit/rest": "^20.1.0",
    "node-fetch": "^2.7.0",
    "undici": "^6.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-fetch": "^2.6.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.0.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.1",
    "husky": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "undici": "^6.24.0"
  }
}
