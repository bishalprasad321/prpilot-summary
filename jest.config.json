{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": [
    "<rootDir>/__tests__",
    "<rootDir>/src"
  ],
  "testMatch": [
    "**/__tests__/**/*.test.ts"
  ],
  "moduleFileExtensions": [
    "ts",
    "js",
    "json"
  ],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "collectCoverage": true,
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts"
  ],
  "coverageReporters": [
    "text-summary",
    "lcov"
  ],
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "/__tests__/"
  ],
  "testPathIgnorePatterns": [
    "/node_modules/",
    "/dist/",
    "/lib/"
  ]
}
